# Aggressive caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/jpg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"

    # CSS and JS
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType application/x-javascript "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpe?g|png|webp)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>

    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# Block well-known malicious scraper/bot agents early
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP_USER_AGENT} "(AhrefsBot|MJ12bot|SemrushBot|BLEXBot|DotBot|sitebulb|Screaming Frog|Nmap|masscan|curl|wget|python-requests|libwww-perl|sqlmap|nikto|ZmEu|Recon-ng|headless|python-urllib|WinHTTP|CensysInspect|fimap)" [NC]
    RewriteRule .* - [F,L]
</IfModule>
